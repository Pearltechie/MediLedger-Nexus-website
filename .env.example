# MediLedger Nexus — environment variable template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Hedera Testnet ──────────────────────────────────────────────────────────
# Your Hedera account ID (e.g. 0.0.1234567)
VITE_HEDERA_ACCOUNT_ID=

# Hex-encoded ECDSA_SECP256K1 private key (no 0x prefix)
VITE_HEDERA_PRIVATE_KEY= 

# The HCS topic ID to anchor records on (e.g. 0.0.7654321)
VITE_HEDERA_TOPIC_ID= 

# ── Pinata IPFS ──────────────────────────────────────────────────────────────
# JWT from app.pinata.cloud → API Keys
VITE_PINATA_JWT= 